# Device Service Configuration
# These variables control where the runtime connects to for PLC/device communication

# Device service host (IP address or hostname)
VITE_DEVICE_HOST=localhost

# Device service port
VITE_DEVICE_PORT=8080

# Alternative: Direct API base URL (overrides VITE_DEVICE_HOST and VITE_DEVICE_PORT)
# VITE_API_BASE_URL=http://192.168.1.100:8080/api/v1
